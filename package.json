{
  "name": "sneak-out-patches",
  "private": true,
  "version": "0.1.0",
  "description": "Sneak Out reverse-engineering, patching, and runtime mod tooling.",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "install": "node scripts/install.mjs",
    "doctor": "node scripts/doctor.mjs",
    "patcher": "node scripts/run-python.mjs tools/patch_sneak_out.py",
    "runtime:session": "node scripts/runtime-session.mjs",
    "runtime:session:host": "node scripts/runtime-session.mjs --host-launch",
    "runtime:profiler:configure": "node scripts/configure-runtime-profiler.mjs",
    "runtime:profiler:off": "node scripts/configure-runtime-profiler.mjs off",
    "interop:inspect": "node scripts/run-dotnet.mjs run --project tools/interop_inspector/InteropInspector.csproj --",
    "mod:list": "node scripts/build-runtime-mod.mjs --list",
    "mod:build": "node scripts/build-runtime-mod.mjs",
    "mods:build": "node scripts/build-runtime-mod.mjs --all",
    "check": "npm run mods:build"
  }
}
