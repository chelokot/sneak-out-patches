{
  "fmt": {
    "lineWidth": 100,
    "singleQuote": false,
    "semiColons": true
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.8.12",
    "@std/assert": "jsr:@std/assert@^1.0.14"
